/*
 * fvOptions.j2 — Source terms for ABL simulation
 *
 * Conditional blocks:
 *   physics.coriolis (default true)  — Coriolis force on U (atmCoriolisUSource)
 *   canopy.enabled   (default false) — Plant canopy drag (atmPlantCanopy* native)
 *
 * Note: ESI v2412 uses native atmCoriolisUSource from atmosphericModels library.
 *       Requires `libs (atmosphericModels);` in controlDict.
 *
 * References:
 *   Sogachev & Panferov (2006) — TKE-dissipation for plant canopy
 *   Letzgus et al. (WES 2023) — Perdigão CFD with k-epsilon + canopy
 */
FoamFile
{
    format      ascii;
    class       dictionary;
    object      fvOptions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

{% if physics.coriolis | default(true) -%}
// -------------------------------------------------------------------------
// Coriolis force (ESI atmCoriolisUSource)
//   Uses the atmosphericModels library (loaded via controlDict libs).
//   f = 2 * Omega * sin(lat), Omega = 7.2921e-5 rad/s
// -------------------------------------------------------------------------
coriolisForce
{
    type            atmCoriolisUSource;

    atmCoriolisUSourceCoeffs
    {
        selectionMode   all;
        latitude        {{ site.latitude | default(39.716) }};
    }
}
{% endif -%}

// NOTE: Boussinesq buoyancy is handled natively by buoyantSimpleFoam
// via the Boussinesq equation of state in thermophysicalProperties.
// No explicit fvOption needed — p_rgh + g provide the buoyancy coupling.

{% if canopy.enabled | default(false) -%}
// -------------------------------------------------------------------------
// Plant canopy sources (native OF2412 atmPlantCanopy*)
//   Requires 0/LAD (volScalarField, leaf area density [1/m])
//   and 0/Cd (volScalarField, drag coefficient [-]) generated by
//   generate_lad_field.py.
//
//   References:
//     Sogachev & Panferov (2006) — k-epsilon canopy model
//     Brozovsky, Simonsen & Gaitani (2021) — validation
// -------------------------------------------------------------------------

canopyDrag
{
    type            atmPlantCanopyUSource;

    atmPlantCanopyUSourceCoeffs
    {
        selectionMode   all;
        Cd              Cd;
        LAD             LAD;
    }
}

canopyTurbulence
{
    type            atmPlantCanopyTurbSource;

    atmPlantCanopyTurbSourceCoeffs
    {
        selectionMode   all;
        Cd              Cd;
        LAD             LAD;
    }
}
{% endif -%}

// ************************************************************************* //
