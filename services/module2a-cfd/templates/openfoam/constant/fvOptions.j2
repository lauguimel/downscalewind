/*
 * fvOptions.j2 — Source terms for ABL simulation
 *
 * Conditional blocks:
 *   physics.coriolis (default true)  — Coriolis force on U (atmCoriolisUSource)
 *   canopy.enabled   (default false) — Plant canopy drag (atmPlantCanopy* native)
 *   solver.thermal   (default false) — Ambient k/ε sources + L_max limiter (BBSF)
 *
 * Note: ESI v2412 uses native atmCoriolisUSource from atmosphericModels library.
 *       Requires `libs (atmosphericModels);` in controlDict.
 *
 * References:
 *   Sogachev & Panferov (2006) — TKE-dissipation for plant canopy
 *   Letzgus et al. (WES 2023) — Perdigão CFD with k-epsilon + canopy
 *   van der Laan et al. (2021) — Ambient source terms for k-ε stability
 *   Venkatraman et al. (WES 2023, Table 3) — kAmb=0.001, εAmb=7.208e-8, Lmax=62.14
 */
FoamFile
{
    format      ascii;
    class       dictionary;
    object      fvOptions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

{% if physics.coriolis | default(true) -%}
// -------------------------------------------------------------------------
// Coriolis force (ESI atmCoriolisUSource)
//   Uses the atmosphericModels library (loaded via controlDict libs).
//   f = 2 * Omega * sin(lat), Omega = 7.2921e-5 rad/s
// -------------------------------------------------------------------------
coriolisForce
{
    type            atmCoriolisUSource;

    atmCoriolisUSourceCoeffs
    {
        selectionMode   all;
        latitude        {{ site.latitude | default(39.716) }};
    }
}
{% endif -%}

// NOTE: Boussinesq buoyancy is handled natively by buoyantBoussinesqSimpleFoam
// via the Boussinesq equation of state in thermophysicalProperties.
// No explicit fvOption needed — p_rgh + g provide the buoyancy coupling.

// -------------------------------------------------------------------------
// Ambient turbulence source terms (Parente et al. 2011)
//   Maintains ABL log-law equilibrium in k-ε by compensating for the
//   numerical imbalance between production and dissipation.
//   Always enabled (SF and BBSF) — without these, the inlet ABL profile
//   degrades as it travels through the domain.
//   Values from Venkatraman et al. (WES 2023), Table 3, k-ε Lim model:
//     kAmb = 0.001 m²/s²  (≈ 0.1% of typical ABL peak TKE)
//     εAmb = 7.208e-8 m²/s³ = Cμ^(3/4) * kAmb^(3/2) / Lmax
//   Reference: van der Laan et al. (2021a), Venkatraman et al. (2023)
// -------------------------------------------------------------------------

ambientTurbSource
{
    type            atmAmbientTurbSource;

    atmAmbientTurbSourceCoeffs
    {
        selectionMode   all;
        kAmb            {{ physics.k_amb | default(0.001) }};
        epsilonAmb      {{ physics.epsilon_amb | default(7.208e-08) }};
    }
}

{% if physics.use_lmax_limiter | default(false) -%}
// -------------------------------------------------------------------------
// Turbulence length scale limiter (Lmax = 62.14 m)
//   Caps the turbulent length scale L = k^(3/2)/ε to prevent unrealistic
//   growth above the ABL. Lmax from Venkatraman et al. (WES 2023) Table 3.
//   NOTE: disabled by default — Venkatraman warns this causes convergence
//   difficulties. Enable with physics.use_lmax_limiter: true only once
//   the ambient source terms alone produce a stable solution.
// -------------------------------------------------------------------------
lengthScaleLimiter
{
    type            atmLengthScaleTurbSource;

    atmLengthScaleTurbSourceCoeffs
    {
        selectionMode   all;
        Lmax            {{ "%.2f" | format(physics.l_max | default(62.14)) }};
    }
}
{% endif -%}

{% if canopy.enabled | default(false) -%}
// -------------------------------------------------------------------------
// Plant canopy sources (native OF2412 atmPlantCanopy*)
//   Requires 0/LAD (volScalarField, leaf area density [1/m])
//   and 0/Cd (volScalarField, drag coefficient [-]) generated by
//   generate_lad_field.py.
//
//   References:
//     Sogachev & Panferov (2006) — k-epsilon canopy model
//     Brozovsky, Simonsen & Gaitani (2021) — validation
// -------------------------------------------------------------------------

canopyDrag
{
    type            atmPlantCanopyUSource;

    atmPlantCanopyUSourceCoeffs
    {
        selectionMode   all;
        Cd              Cd;
        LAD             LAD;
    }
}

canopyTurbulence
{
    type            atmPlantCanopyTurbSource;

    atmPlantCanopyTurbSourceCoeffs
    {
        selectionMode   all;
        Cd              Cd;
        LAD             LAD;
    }
}
{% endif -%}

// ************************************************************************* //
