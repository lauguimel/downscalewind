// k-omega SST turbulence model for ABL simulation (OF10 Foundation name)
// Replaces turbulenceProperties from pre-v10.

simulationType RAS;

RAS
{
    model           kOmegaSST;
    turbulence      on;
    printCoeffs     on;
}

