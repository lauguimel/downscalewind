/*
 * momentumTransport — Turbulence model configuration (ESI v2412)
 *
 * Standard k-epsilon for ABL simulation.
 * References:
 *   Richards & Hoxey (1993) — ABL equilibrium profiles for k-epsilon
 *   Parente et al. (2011)   — Modified k-epsilon for horizontal homogeneity
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      momentumTransport;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType  RAS;

RAS
{
    RASModel        kEpsilon;

    turbulence      on;

    printCoeffs     yes;
}

// ************************************************************************* //
