/*
 * momentumTransport.j2 — Turbulence model configuration
 *
 * OF10 Foundation: file = constant/momentumTransport, object = momentumTransport
 * OF9  Foundation: file = constant/turbulenceProperties, object = turbulenceProperties
 *
 * The of_version variable controls the object name; the file rename is
 * handled by generate_mesh.py post-render step.
 */
{%- set obj_name = "turbulenceProperties" if of_version | default(10) | int == 9 else "momentumTransport" %}
FoamFile
{
    format      ascii;
    class       dictionary;
    object      {{ obj_name }};
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// k-epsilon turbulence model for ABL simulation

simulationType RAS;

RAS
{
    model           kEpsilon;
    turbulence      on;
    printCoeffs     on;
}

