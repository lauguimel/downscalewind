/*
 * thermophysicalProperties.j2 — Thermophysical model for ABL simulation
 *
 * Required by buoyantSimpleFoam.  NOT used by simpleFoam.
 *
 * Equation of state controlled by solver.boussinesq (default: true):
 *   - Boussinesq (default): rho = rho0 * [1 - beta*(T - T0)]
 *     Native ESI v2412 Boussinesq EoS — incompressible with linear
 *     buoyancy coupling.  beta = 1/T_ref for ideal gas approximation.
 *   - Compressible: ideal gas rho = p/(R*T)
 *     More realistic but harder to converge; requires tighter relaxation.
 *
 * Variables:
 *   physics.T_ref_K      — reference temperature [K] (default 288.15)
 *   physics.rho_ref      — reference density [kg/m³] (default 1.225)
 *   solver.boussinesq    — if true, use Boussinesq EoS (default: true)
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

{%- set T_ref = physics.T_ref_K | default(288.15) %}
{%- set rho_ref = physics.rho_ref | default(1.225) %}
{%- set boussinesq = solver.boussinesq | default(true) %}
{#- beta = 1/T_ref for ideal gas Boussinesq approximation -#}
{%- set beta = 1.0 / T_ref %}

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
{%- if boussinesq %}
    equationOfState Boussinesq;
{%- else %}
    equationOfState perfectGas;
{%- endif %}
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight       28.9;   // Dry air [g/mol]
    }
    thermodynamics
    {
        Cp          1005;       // Specific heat capacity [J/(kg.K)]
        Hf          0;          // Heat of formation [J/kg]
    }
    transport
    {
        mu          1.81e-5;    // Dynamic viscosity [Pa.s] at ~288K
        Pr          0.71;       // Laminar Prandtl number
    }
{%- if boussinesq %}
    equationOfState
    {
        rho0        {{ rho_ref }};       // Reference density [kg/m³]
        T0          {{ T_ref }};         // Reference temperature [K]
        beta        {{ "%.6e" | format(beta) }};  // Thermal expansion coeff [1/K] = 1/T_ref
    }
{%- endif %}
}

