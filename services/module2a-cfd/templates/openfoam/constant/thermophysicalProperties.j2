/*
 * thermophysicalProperties.j2 — Thermophysical model for ABL simulation
 *
 * Required by buoyantSimpleFoam.
 * NOT used by simpleFoam.
 *
 * Two modes controlled by solver.boussinesq (default: false):
 *   - Boussinesq: rhoConst + explicit buoyancy fvOption
 *     Replicates the old buoyantBoussinesqSimpleFoam behaviour.
 *     rhoConst avoids heRhoThermo Newton divergence; buoyancy enters
 *     only through a coded momentum source (Boussinesq approximation).
 *   - Compressible: ideal gas rho = p/(R*T)
 *
 * Variables:
 *   physics.T_ref_K      — reference temperature [K] (default 300)
 *   solver.boussinesq    — if true, use rhoConst + buoyancy source (default: false)
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

{%- set T_ref = physics.T_ref_K | default(300.0) %}
{%- set boussinesq = solver.boussinesq | default(false) %}

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
{%- if boussinesq %}
    equationOfState rhoConst;          // constant density; buoyancy via fvOption
{%- else %}
    equationOfState perfectGas;        // rho = p / (R * T)
{%- endif %}
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight       28.9;   // Dry air [g/mol]
    }
    thermodynamics
    {
        Cp          1005;       // Specific heat capacity [J/(kg.K)]
        Hf          0;          // Heat of formation
    }
    transport
    {
        mu          1.81e-5;    // Dynamic viscosity [Pa.s] at ~300K
        Pr          0.71;       // Laminar Prandtl number
    }
{%- if boussinesq %}
    equationOfState
    {
        rho         1.225;      // Constant density [kg/m³]
    }
{%- endif %}
}

// ************************************************************************* //
