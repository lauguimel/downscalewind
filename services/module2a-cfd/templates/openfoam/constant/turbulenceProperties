/*
 * turbulenceProperties — static file (no Jinja2 templating needed)
 * Standard k-epsilon turbulence model for ABL simulation
 *
 * k-epsilon is the validated closure for steady-state ABL flows over
 * complex terrain at Perdigão (Letzgus et al., WES 2023; Neunaber et al.,
 * WES 2022; Palma et al., WES 2020). It is consistent with the
 * atmBoundaryLayer* inlet BCs and atmPlantCanopy* source terms in
 * OpenFOAM ESI v2006+.
 *
 * References:
 *   Richards & Hoxey (1993) — ABL equilibrium profiles for k-epsilon
 *   Parente et al. (2011)   — Modified k-epsilon for horizontal homogeneity
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      turbulenceProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType  RAS;

RAS
{
    RASModel        kEpsilon;

    turbulence      on;

    printCoeffs     yes;    // Print model coefficients to stdout at startup

    // Standard k-epsilon coefficients (Launder & Spalding, 1974)
    // Cmu         0.09;
    // C1          1.44;
    // C2          1.92;
    // sigmaK      1.0;
    // sigmaEps    1.3;
}

