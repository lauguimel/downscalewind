/*
 * turbulenceProperties — static file (no Jinja2 templating needed)
 * k-omega SST turbulence model for ABL simulation
 *
 * k-omega SST (Menter 1994) is the recommended closure for ABL flows over
 * complex terrain: it blends k-omega near walls with k-epsilon in the free
 * stream, handles adverse pressure gradients, and is compatible with the
 * atmBoundaryLayer* boundary conditions in OpenFOAM 9.
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      turbulenceProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType  RAS;

RAS
{
    // k-omega SST: shear stress transport variant of k-omega
    RASModel        kOmegaSST;

    turbulence      on;

    printCoeffs     yes;    // Print model coefficients to stdout at startup

    // Model coefficients — default Menter (1994) values
    // alphaK1     0.85;
    // alphaK2     1.0;
    // alphaOmega1 0.5;
    // alphaOmega2 0.856;
    // beta1       0.075;
    // beta2       0.0828;
    // betaStar    0.09;
    // gamma1      0.5555;
    // gamma2      0.4403;
    // a1          0.31;
    // b1          1.0;
    // c1          10.0;
    // F3          no;
}

