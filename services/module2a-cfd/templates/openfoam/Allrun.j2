#!/bin/sh
cd ${0%/*} || exit 1    # run from this directory

# Source tutorial run functions
. $WM_PROJECT_DIR/bin/tools/RunFunctions

if [ "$#" -lt 1 ]; then
    echo "Usage: ./Allrun <nProcs> [--mesh-only]"
    echo "  nProcs     Number of processors"
    echo "  --mesh-only  Stop after mesh generation (for ParaView check)"
    exit 1
fi

NPROCS=$1
MESH_ONLY=false
if [ "${2:-}" = "--mesh-only" ]; then
    MESH_ONLY=true
fi

SOLVER="{{ solver.name | default('simpleFoam') }}"

# Helper: check that the last command succeeded
check_log() {
    LOG=$1
    if grep -q "FOAM FATAL" "$LOG" 2>/dev/null; then
        echo "========================================" >&2
        echo "ERROR: $(basename $LOG .log) failed — see $LOG" >&2
        tail -5 "$LOG" >&2
        echo "========================================" >&2
        exit 1
    fi
}

# ---- Mesh generation (cfMesh cartesianMesh) ----
# domain.fms is pre-generated by generate_mesh.py (Python build_domain_fms)
# It contains the terrain STL + 5 bounding box faces as a closed FMS surface.
runApplication cartesianMesh
check_log log.cartesianMesh

runApplication checkMesh -latestTime

if [ "$MESH_ONLY" = true ]; then
    echo "========================================"
    echo "Mesh generation complete (--mesh-only)."
    echo "Open case.foam in ParaView to inspect."
    echo "========================================"
    exit 0
fi

# ---- Field initialisation from ERA5/parametric profiles ----
# Patches both internalField (cell centres) and boundaryField (face centres)
# with height-varying U(z), k, epsilon(z), T(z) from the inflow profile.
# Requires Python (numpy + scipy) — available via module load on HPC.

INFLOW_JSON="{{ inflow_json_path | default('inflow.json') }}"

if [ -f "$INFLOW_JSON" ] && command -v python3 > /dev/null 2>&1; then
    echo "Initialising fields from $INFLOW_JSON (init_from_era5.py)"
    # Write cell centres (needed by init_from_era5.py)
    postProcess -func writeCellCentres -time 0 > log.writeCellCentres 2>&1 || true
    python3 init_from_era5.py --case-dir . --inflow "$INFLOW_JSON" \
        > log.init_from_era5 2>&1
    if [ $? -ne 0 ]; then
        echo "WARNING: init_from_era5.py failed — falling back to potentialFoam" >&2
        cat log.init_from_era5 >&2
        runApplication potentialFoam -writePhi
        check_log log.potentialFoam
    else
        echo "Fields initialised: U(z), k, epsilon(z), T(z)"
    fi
else
    echo "WARNING: Python or inflow JSON not found — using potentialFoam" >&2
    runApplication potentialFoam -writePhi
    check_log log.potentialFoam
fi

# ---- Main solve ----
if [ "$NPROCS" -gt 1 ]; then
    foamDictionary system/decomposeParDict -entry numberOfSubdomains -set $NPROCS
    runApplication decomposePar
    runParallel $SOLVER
    check_log log.$SOLVER
    runApplication reconstructPar -latestTime
else
    runApplication $SOLVER
    check_log log.$SOLVER
fi

# ---- Post-processing: sample profiles at tower locations ----
# Non-fatal: postProcess may fail on some OF versions without affecting results
if [ -f system/sampleDict ]; then
    postProcess -func sampleDict -latestTime > log.postProcess 2>&1 || true
fi

echo "========================================"
echo "Run complete."
echo "========================================"
