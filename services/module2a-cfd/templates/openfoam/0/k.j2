/*
 * 0/k.j2 — Turbulent kinetic energy [m²/s²]
 *
 * k = u_star² / sqrt(Cmu) — ABL equilibrium value
 *
 * BC strategy:
 *   Lateral:  uniformMixed + MappedFile (inlet: k profile, outlet: zeroGradient)
 *   Top:      zeroGradient
 *   Terrain:  kqRWallFunction
 */
{%- set Cmu = 0.09 %}
{%- set k_init = inflow.u_star ** 2 / Cmu ** 0.5 %}
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// k_init = u_star²/√Cmu = {{ inflow.u_star }}²/√{{ Cmu }} = {{ "%.4f" | format(k_init) }} m²/s²

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform {{ "%.6f" | format(k_init) }};

boundaryField
{
{% if domain is defined and domain.octagonal %}
    lateral
    {
        type            uniformMixed;
        uniformValue
        {
            type        mappedFile;
            mapMethod   planar;
            fieldTable  k;
        }
        uniformGradient zero;
        uniformValueFraction
        {
            type        expression;
            expression  "neg(phi)";
        }
        value           uniform {{ "%.6f" | format(k_init) }};
    }

{% else %}
{% for face in ['west', 'east', 'south', 'north'] %}
    {{ face }}
    {
        type            uniformMixed;
        uniformValue
        {
            type        mappedFile;
            mapMethod   planar;
            fieldTable  k;
        }
        uniformGradient zero;
        uniformValueFraction
        {
            type        expression;
            expression  "neg(phi)";
        }
        value           uniform {{ "%.6f" | format(k_init) }};
    }

{% endfor %}
{% endif %}
    top
    {
        type            inletOutlet;
        inletValue      uniform {{ "%.6f" | format(k_init) }};
        value           uniform {{ "%.6f" | format(k_init) }};
    }

    terrain
    {
        type            kqRWallFunction;
        value           uniform {{ "%.6f" | format(k_init) }};
    }

    bottom
    {
        type            kqRWallFunction;
        value           uniform {{ "%.6f" | format(k_init) }};
    }
}

