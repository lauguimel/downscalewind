/*
 * 0/T.j2 — Temperature boundary conditions
 *
 * BC strategy:
 *   Lateral + top:  inletOutlet (inlet: T(z) profile, outlet: zeroGradient)
 *   Terrain:        zeroGradient (neutral) or fixedValue (non-neutral)
 *   Bottom:         zeroGradient
 *
 * After mesh generation, init_from_era5.py patches inletValue/value to
 * nonuniform height-varying T(z) profiles.
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// T_ref = {{ inflow.T_ref }} K
// L_mo  = {{ inflow.L_mo }} m  (0/None = neutral, >0 = stable, <0 = unstable)
// NOTE: inletValue/value are placeholders — patched to nonuniform by init_from_era5.py

dimensions      [0 0 0 1 0 0 0];

internalField   uniform {{ inflow.T_ref }};

boundaryField
{
{% for face in ['west', 'east', 'south', 'north'] %}
    {{ face }}
    {
        type            inletOutlet;
        inletValue      uniform {{ inflow.T_ref }};
        value           uniform {{ inflow.T_ref }};
    }

{% endfor %}
    top
    {
        type            inletOutlet;
        inletValue      uniform {{ inflow.T_ref }};
        value           uniform {{ inflow.T_ref }};
    }

    terrain
    {
{%- if inflow.L_mo is none or inflow.L_mo == 0 %}
        // Neutral stratification: no surface heat flux
        type            zeroGradient;
{%- else %}
        // Non-neutral: uniform surface temperature (first approximation)
        type            fixedValue;
        value           uniform {{ inflow.T_ref }};
{%- endif %}
    }

    bottom
    {
        type            zeroGradient;
    }
}

// ************************************************************************* //
