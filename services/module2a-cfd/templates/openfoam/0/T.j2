/*
 * 0/T.j2 — Temperature boundary conditions
 *
 * BC strategy:
 *   Lateral:  uniformMixed + MappedFile (inlet: T(z), outlet: zeroGradient)
 *   Top:      zeroGradient (free boundary — pressure anchored by fixedValue p_rgh)
 *   Terrain:  zeroGradient (neutral) or fixedValue (non-neutral)
 *   Bottom:   zeroGradient
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// T_ref = {{ inflow.T_ref }} K
// L_mo  = {{ inflow.L_mo }} m  (0/None = neutral, >0 = stable, <0 = unstable)

dimensions      [0 0 0 1 0 0 0];

internalField   uniform {{ inflow.T_ref }};

boundaryField
{
{% for face in ['west', 'east', 'south', 'north'] %}
    {{ face }}
    {
        type            uniformMixed;
        uniformValue
        {
            type        mappedFile;
            mapMethod   planar;
            fieldTable  T;
        }
        uniformGradient zero;
        uniformValueFraction
        {
            type        expression;
            expression  "neg(phi)";
        }
        value           uniform {{ inflow.T_ref }};
    }

{% endfor %}
    top
    {
        type            zeroGradient;
    }

    terrain
    {
{%- if inflow.L_mo is none or inflow.L_mo == 0 %}
        // Neutral stratification: no surface heat flux
        type            zeroGradient;
{%- else %}
        // Non-neutral: uniform surface temperature (first approximation)
        type            fixedValue;
        value           uniform {{ inflow.T_ref }};
{%- endif %}
    }

    bottom
    {
        type            zeroGradient;
    }
}

// ************************************************************************* //
