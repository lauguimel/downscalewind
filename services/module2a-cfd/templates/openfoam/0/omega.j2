/*
 * 0/omega.j2 — Specific dissipation rate [1/s]
 *
 * omega_init = u_star / (kappa * z_ref) — ABL equilibrium at reference height
 *
 * BC strategy:
 *   Inlet faces:  fixedValue (ABL-consistent omega)
 *   Outlet faces: zeroGradient
 *   Top:          zeroGradient
 *   Terrain:      omegaWallFunction
 */
{%- set omega_init = inflow.u_star / (inflow.kappa * inflow.z_ref) %}
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// omega_init = {{ inflow.u_star }} / ({{ inflow.kappa }} * {{ inflow.z_ref }}) = {{ "%.6f" | format(omega_init) }} s⁻¹

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform {{ "%.6f" | format(omega_init) }};

boundaryField
{
{% for face in ['west', 'east', 'south', 'north'] %}
    {{ face }}
    {
{%- if face in inlet_faces %}
        type            fixedValue;
        value           uniform {{ "%.6f" | format(omega_init) }};
{%- else %}
        type            zeroGradient;
{%- endif %}
    }

{% endfor %}
    top
    {
        type            zeroGradient;
    }

    terrain
    {
        type            omegaWallFunction;
        value           uniform {{ "%.6f" | format(omega_init) }};
    }

    bottom
    {
        type            omegaWallFunction;
        value           uniform {{ "%.6f" | format(omega_init) }};
    }
}

