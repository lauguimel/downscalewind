/*
 * 0/p_rgh.j2 — Modified pressure boundary conditions
 *
 * p_rgh = p - rho * g * h   (buoyantBoussinesqSimpleFoam)
 * p_rgh ≡ p/rho             (simpleFoam, kinematic)
 *
 * BC strategy (DUAL of U — opposite fraction):
 *   Lateral faces:  uniformMixed + MappedFile with pos(phi) fraction.
 *                   Dirichlet p(z) on OUTLET faces (where U is Neumann),
 *                   Neumann on INLET faces (where U is Dirichlet).
 *   Top:           fixedFluxPressure (consistent with uniformMixed U)
 *   Terrain/bottom: fixedFluxPressure (no-penetration wall)
 *
 * Profiles are written by init_from_era5.py into constant/boundaryData/.
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
{% for face in ['west', 'east', 'south', 'north'] %}
    {{ face }}
    {
        type            uniformMixed;
        uniformValue
        {
            type        mappedFile;
            mapMethod   planar;
            fieldTable  p_rgh;
        }
        uniformGradient  zero;
        uniformValueFraction
        {
            type        expression;
            expression  "pos(phi)";   // DUAL of U: Dirichlet on outlet, Neumann on inlet
        }
        value           uniform 0;
    }

{% endfor %}
    top
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform 0;
    }

    terrain
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform 0;
    }

    bottom
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform 0;
    }
}

