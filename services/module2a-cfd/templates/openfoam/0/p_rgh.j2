/*
 * 0/p_rgh.j2 — Modified pressure boundary conditions
 *
 * p_rgh = p - rho * g * h   (buoyantBoussinesqSimpleFoam)
 * p_rgh ≡ p/rho             (simpleFoam, kinematic)
 *
 * BC strategy (dual of U):
 *   Lateral faces:  outletInlet — Dirichlet p(z) on OUTLET faces (where U
 *                   is zeroGradient), zeroGradient on INLET faces (where U
 *                   is prescribed). This avoids over-constraining: we never
 *                   impose both U and p on the same face.
 *   Top:           fixedFluxPressure (consistent with inletOutlet U)
 *   Terrain/bottom: fixedFluxPressure (no-penetration wall)
 *
 * After mesh generation, init_from_era5.py patches outletValue/value to
 * nonuniform p_rgh(z) = p(z) - rho0*g*z from ERA5 pressure levels.
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// NOTE: outletValue/value are placeholders — patched to nonuniform by init_from_era5.py

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
{% for face in ['west', 'east', 'south', 'north'] %}
    {{ face }}
    {
        type            outletInlet;
        outletValue     uniform 0;
        value           uniform 0;
    }

{% endfor %}
    top
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform 0;
    }

    terrain
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform 0;
    }

    bottom
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform 0;
    }
}

