/*
 * 0/p_rgh.j2 — Jinja2 template
 * Initial and boundary conditions for modified pressure p_rgh [Pa]
 *
 * p_rgh = p - rho * g * h
 *   where h is the height above a reference datum.
 * buoyantBoussinesqSimpleFoam solves for p_rgh rather than p to decouple
 * the hydrostatic pressure gradient from the dynamic pressure.
 * For simpleFoam (neutral), p_rgh ≡ p (no buoyancy correction).
 *
 * Variables:
 *   physics.p_ref_Pa   — reference gauge pressure [Pa] (usually 0)
 *   physics.rho_ref    — reference density [kg/m³] (1.225)
 *
 * Boundary condition choices:
 *   Inlet faces:     fixedFluxPressure
 *     Adjusts the pressure gradient at the boundary to be consistent with
 *     the specified velocity flux.  Prevents spurious reflections.
 *   Outlet / top:   totalPressure with p0 = 0
 *     Fixes total pressure; allows flow to leave without reflecting.
 *   Terrain / wall:  fixedFluxPressure
 *     No-penetration at wall is enforced via U; pressure gradient is
 *     adjusted to match the zero normal flux constraint.
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// p_ref = {{ physics.p_ref_Pa | default(0) }} Pa (gauge)
// rho_ref = {{ physics.rho_ref | default(1.225) }} kg/m³

dimensions      [1 -1 -2 0 0 0 0];

{%- set boussinesq = solver.boussinesq | default(false) %}
{%- set p_init = 0 if boussinesq else 101325 %}
// Boussinesq: gauge pressure (rho independent of p, es=Cp*T is linear)
// perfectGas: atmospheric (rho=p/(RT) needs realistic p to avoid negative T)
internalField   uniform {{ p_init }};

boundaryField
{
    // -----------------------------------------------------------------------
    // Lateral faces:
    //   simpleFoam / buoyantBoussinesqSimpleFoam (incompressible):
    //     fixedValue 0 — zero kinematic gauge pressure, Dirichlet constraint.
    //   buoyantSimpleFoam (compressible, p in Pa):
    //     fixedFluxPressure — adjusts gradient to be consistent with inletOutlet
    //     velocity flux on lateral faces. Prevents singularity in compressible
    //     pressure Poisson when combined with non-trivial hydrostatic field.
    //
    // Top: fixedValue 0 for all solvers (clean Dirichlet at domain ceiling).
    // -----------------------------------------------------------------------
{% if solver.name | default("simpleFoam") == "buoyantSimpleFoam" %}
    west
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform {{ p_init }};
    }

    east
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform {{ p_init }};
    }

    south
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform {{ p_init }};
    }

    north
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform {{ p_init }};
    }
{% else %}
    west
    {
        type            fixedValue;
        value           uniform 0;
    }

    east
    {
        type            fixedValue;
        value           uniform 0;
    }

    south
    {
        type            fixedValue;
        value           uniform 0;
    }

    north
    {
        type            fixedValue;
        value           uniform 0;
    }
{% endif %}

    top
    {
        type            fixedValue;
        value           uniform {{ p_init }};
    }

    // -----------------------------------------------------------------------
    // Terrain wall: fixedFluxPressure
    //   No normal flow at wall; pressure gradient adjusted accordingly.
    // -----------------------------------------------------------------------
    terrain
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform {{ p_init }};
    }

    bottom
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform {{ p_init }};
    }
}

// ************************************************************************* //
