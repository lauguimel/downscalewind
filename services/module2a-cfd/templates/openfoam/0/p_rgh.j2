/*
 * 0/p_rgh.j2 — Modified pressure boundary conditions
 *
 * p_rgh = p/rho0 + g*z      (buoyantBoussinesqSimpleFoam, kinematic)
 *   OF: p = p_rgh + rhok*gh, gh = g·h = -9.81*z → p_rgh = p/rho0 + g*z
 *   Hydrostatic check: dp_rgh/dz ≈ 0 (neutral, rhok=1) ✓
 * p_rgh ≡ p/rho0            (simpleFoam, kinematic — hydrostatic in p implicitly)
 *
 * BC strategy:
 *   Lateral faces:  uniformMixed + MappedFile with pos(phi) fraction.
 *                   Dirichlet p(z) on OUTLET faces (where U is Neumann),
 *                   Neumann on INLET faces (where U is Dirichlet).
 *   Top:           fixedValue = ERA5 hydrostatic p_rgh at domain top
 *                  (anchors synoptic pressure; U is free via zeroGradient)
 *   Terrain/bottom: fixedFluxPressure (no-penetration wall)
 *
 * Profiles are written by init_from_era5.py into constant/boundaryData/.
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
{% for face in ['west', 'east', 'south', 'north'] %}
    {{ face }}
    {
        type            uniformMixed;
        uniformValue
        {
            type        mappedFile;
            mapMethod   planar;
            fieldTable  p_rgh;
        }
        uniformGradient  zero;
        uniformValueFraction
        {
            type        expression;
            expression  "pos(phi)";   // DUAL of U: Dirichlet on outlet, Neumann on inlet
        }
        value           uniform 0;
    }

{% endfor %}
    top
    {
        // p_rgh_top = p_ERA5(z_top)/rho0 + g*z_top [m2/s2] (OF sign convention)
        // Anchors synoptic pressure; velocity adjusts freely (zeroGradient U).
        type            fixedValue;
        value           uniform {{ "%.4f" | format(physics.p_rgh_top) }};
    }

    terrain
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform 0;
    }

    bottom
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform 0;
    }
}

