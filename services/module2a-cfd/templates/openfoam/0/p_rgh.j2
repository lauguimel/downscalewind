/*
 * 0/p_rgh.j2 — Modified pressure boundary conditions (BBSF)
 *
 * p_rgh is a Lagrange multiplier enforcing ∇·U = 0 in Boussinesq.
 * It is NOT a thermodynamic pressure — ERA5 values must NOT be imposed.
 *
 * BC strategy (dual of U):
 *   U lateral:     neg(phi) → Dirichlet ERA5 (inlet), Neumann (outlet)
 *   p_rgh lateral: pos(phi) → Dirichlet 0 (outlet), Neumann (inlet)
 *   Top:           zeroGradient — free for orographic waves.
 *   Terrain:       fixedFluxPressure (no-penetration wall).
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
{% set lateral_faces = domain.lateral_patches | default(['lateral']) if (domain is defined and domain.octagonal) else ['west', 'east', 'south', 'north'] %}
{% for face in lateral_faces %}
    {{ face }}
    {
        type            uniformMixed;
        uniformValue    uniform 0;
        uniformGradient zero;
        uniformValueFraction
        {
            type        expression;
            expression  "pos(phi)";   // Dirichlet 0 on OUTLET, Neumann on INLET
        }
        value           uniform 0;
    }

{% endfor %}
    top
    {
        type            zeroGradient;
    }

    terrain
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform 0;
    }

    bottom
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform 0;
    }
}

