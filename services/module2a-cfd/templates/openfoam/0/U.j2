/*
 * 0/U.j2 — Velocity boundary conditions
 *
 * BC strategy (Robin / inletOutlet on all lateral faces):
 *   All lateral:  inletOutlet — Dirichlet (inflow) or Neumann (outflow)
 *                 determined per-face by sign of flux · face normal
 *   Top:          slip (Venkatraman et al. WES 2023)
 *   Terrain:      noSlip
 *
 * Reference: Venkatraman et al. (WES 2023) — cylindrical domain with Robin BC
 */
{%- set fd_x = inflow.flowDir_x -%}
{%- set fd_y = inflow.flowDir_y -%}
FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Wind direction: {{ inflow.wind_dir }}° FROM North
// Flow direction (CFD): ({{ "%.4f" | format(fd_x) }}, {{ "%.4f" | format(fd_y) }}, 0)
// u_hub = {{ inflow.u_hub }} m/s
// Robin BC: inletOutlet on all lateral faces (auto inlet/outlet per cell face)

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform ( {{ "%.6f" | format(inflow.u_hub * fd_x) }} {{ "%.6f" | format(inflow.u_hub * fd_y) }} 0 );

boundaryField
{
{% for face in ['west', 'east', 'south', 'north'] %}
    {{ face }}
    {
        type            inletOutlet;
        inletValue      uniform ( {{ "%.6f" | format(inflow.u_hub * fd_x) }} {{ "%.6f" | format(inflow.u_hub * fd_y) }} 0 );
        value           uniform ( {{ "%.6f" | format(inflow.u_hub * fd_x) }} {{ "%.6f" | format(inflow.u_hub * fd_y) }} 0 );
    }

{% endfor %}
    top
    {
        type            slip;
    }

    terrain
    {
        type            noSlip;
    }

    bottom
    {
        type            noSlip;
    }
}

// ************************************************************************* //
