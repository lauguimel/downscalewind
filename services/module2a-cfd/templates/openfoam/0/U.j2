/*
 * 0/U.j2 — Velocity boundary conditions
 *
 * BC strategy (uniformMixed + MappedFile on all lateral faces):
 *   Lateral:  uniformMixed — reads height-varying ERA5 profiles from
 *             constant/boundaryData/<patch>/0/U (MappedFile).
 *             Inlet/outlet switching via phi: neg(phi) → Dirichlet (inlet),
 *             pos(phi) → Neumann/zeroGradient (outlet).
 *   Top:      uniformMixed (same strategy)
 *   Terrain:  noSlip
 *
 * Profiles are written by init_from_era5.py into constant/boundaryData/.
 *
 * Reference: Venkatraman et al. (WES 2023) — cylindrical domain with Robin BC
 */
{%- set fd_x = inflow.flowDir_x -%}
{%- set fd_y = inflow.flowDir_y -%}
FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Wind direction: {{ inflow.wind_dir }}° FROM North
// Flow direction (CFD): ({{ "%.4f" | format(fd_x) }}, {{ "%.4f" | format(fd_y) }}, 0)
// u_hub = {{ inflow.u_hub }} m/s

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform ( {{ "%.6f" | format(inflow.u_hub * fd_x) }} {{ "%.6f" | format(inflow.u_hub * fd_y) }} 0 );

boundaryField
{
{% for face in ['west', 'east', 'south', 'north'] %}
    {{ face }}
    {
        type            uniformMixed;
        uniformValue
        {
            type        mappedFile;
            mapMethod   planar;
            fieldTable  U;
        }
        uniformGradient zero;
        uniformValueFraction
        {
            type        expression;
            expression  "neg(phi)";
        }
        value           uniform ( {{ "%.6f" | format(inflow.u_hub * fd_x) }} {{ "%.6f" | format(inflow.u_hub * fd_y) }} 0 );
    }

{% endfor %}
    top
    {
        type            uniformMixed;
        uniformValue
        {
            type        mappedFile;
            mapMethod   planar;
            fieldTable  U;
        }
        uniformGradient zero;
        uniformValueFraction
        {
            type        expression;
            expression  "neg(phi)";
        }
        value           uniform ( {{ "%.6f" | format(inflow.u_hub * fd_x) }} {{ "%.6f" | format(inflow.u_hub * fd_y) }} 0 );
    }

    terrain
    {
        type            noSlip;
    }

    bottom
    {
        type            noSlip;
    }
}

