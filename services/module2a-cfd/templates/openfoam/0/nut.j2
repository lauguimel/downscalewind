/*
 * 0/nut.j2 — Turbulent kinematic viscosity for k-epsilon
 *
 * nut is a derived quantity computed from k and epsilon by the turbulence model.
 * Initial value: nut_0 = Cmu * k_0² / epsilon_0
 * All boundaries are 'calculated' except walls which use nutkAtmRoughWallFunction
 * (ABL rough wall, Parente et al. 2011) with aerodynamic roughness z0.
 */
{%- set Cmu = 0.09 %}
{%- set k_init       = inflow.u_star ** 2 / Cmu ** 0.5 %}
{%- set epsilon_init = Cmu ** 0.75 * k_init ** 1.5 / (inflow.kappa * inflow.z_ref) %}
{%- set nut_init     = Cmu * k_init ** 2 / epsilon_init %}
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform {{ "%.6e" | format(nut_init) }};

boundaryField
{
{% set lateral_faces = domain.lateral_patches | default(['lateral']) if (domain is defined and domain.octagonal) else ['west', 'east', 'south', 'north'] %}
{% for face in lateral_faces %}
    {{ face }}
    {
        type            calculated;
        value           uniform {{ "%.6e" | format(nut_init) }};
    }

{% endfor %}
    top
    {
        type            calculated;
        value           uniform {{ "%.6e" | format(nut_init) }};
    }

    terrain
    {
        type            atmNutkWallFunction;
{%- if physics.z0_mapped | default(false) %}
        z0
        {
            type        mappedFile;
            mapMethod   planar;
            fieldTable  z0;
        }
{%- else %}
        z0              uniform {{ inflow.z0_eff | default(0.05) }};
{%- endif %}
        value           uniform {{ "%.6e" | format(nut_init) }};
    }

    bottom
    {
        type            atmNutkWallFunction;
        z0              uniform {{ inflow.z0_eff | default(0.05) }};
        value           uniform {{ "%.6e" | format(nut_init) }};
    }
}

