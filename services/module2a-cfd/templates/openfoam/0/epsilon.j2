/*
 * 0/epsilon.j2 — Turbulent dissipation rate [m²/s³]
 *
 * epsilon(z) = Cmu^0.75 * k^1.5 / (kappa * max(z, 2*z0))
 *   ABL equilibrium profile (Richards & Hoxey 1993)
 *
 * BC strategy:
 *   Lateral:  inletOutlet (inlet: epsilon(z) profile, outlet: zeroGradient)
 *   Top:      zeroGradient
 *   Terrain:  epsilonWallFunction
 *
 * After mesh generation, init_from_era5.py patches inletValue/value to
 * nonuniform height-varying epsilon(z) profiles.
 */
{%- set Cmu = 0.09 %}
{%- set k_init = inflow.u_star ** 2 / Cmu ** 0.5 %}
{%- set epsilon_init = Cmu ** 0.75 * k_init ** 1.5 / (inflow.kappa * inflow.z_ref) %}
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// epsilon_init = Cmu^0.75 * k^1.5 / (kappa * z_ref)
//             = {{ "%.6e" | format(epsilon_init) }} m²/s³

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform {{ "%.6e" | format(epsilon_init) }};

boundaryField
{
{% for face in ['west', 'east', 'south', 'north'] %}
    {{ face }}
    {
        type            inletOutlet;
        inletValue      uniform {{ "%.6e" | format(epsilon_init) }};
        value           uniform {{ "%.6e" | format(epsilon_init) }};
    }

{% endfor %}
    top
    {
        type            zeroGradient;
    }

    terrain
    {
        type            epsilonWallFunction;
        value           uniform {{ "%.6e" | format(epsilon_init) }};
    }

    bottom
    {
        type            epsilonWallFunction;
        value           uniform {{ "%.6e" | format(epsilon_init) }};
    }
}

