/*
 * 0/epsilon.j2 — Turbulent dissipation rate [m²/s³]
 *
 * epsilon(z) = Cmu^0.75 * k^1.5 / (kappa * max(z, 2*z0))
 *   ABL equilibrium profile (Richards & Hoxey 1993)
 *
 * BC strategy:
 *   Lateral:  uniformMixed + MappedFile (inlet: epsilon(z), outlet: zeroGradient)
 *   Top:      zeroGradient
 *   Terrain:  atmEpsilonWallFunction (Parente et al. 2011) with z0
 */
{%- set Cmu = 0.09 %}
{%- set k_init = inflow.u_star ** 2 / Cmu ** 0.5 %}
{%- set epsilon_init = Cmu ** 0.75 * k_init ** 1.5 / (inflow.kappa * inflow.z_ref) %}
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// epsilon_init = Cmu^0.75 * k^1.5 / (kappa * z_ref)
//             = {{ "%.6e" | format(epsilon_init) }} m²/s³

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform {{ "%.6e" | format(epsilon_init) }};

boundaryField
{
{% set lateral_faces = domain.lateral_patches | default(['lateral']) if (domain is defined and domain.octagonal) else ['west', 'east', 'south', 'north'] %}
{% for face in lateral_faces %}
    {{ face }}
    {
        type            uniformMixed;
        uniformValue
        {
            type        mappedFile;
            mapMethod   planar;
            fieldTable  epsilon;
        }
        uniformGradient zero;
        uniformValueFraction
        {
            type        expression;
            expression  "neg(phi)";
        }
        value           uniform {{ "%.6e" | format(epsilon_init) }};
    }

{% endfor %}
    top
    {
        type            inletOutlet;
        inletValue      uniform {{ "%.6e" | format(epsilon_init) }};
        value           uniform {{ "%.6e" | format(epsilon_init) }};
    }

    terrain
    {
        type            atmEpsilonWallFunction;
{%- if physics.z0_mapped | default(false) %}
        z0
        {
            type        mappedFile;
            mapMethod   planar;
            fieldTable  z0;
        }
{%- else %}
        z0              uniform {{ inflow.z0_eff | default(0.05) }};
{%- endif %}
        value           uniform {{ "%.6e" | format(epsilon_init) }};
    }

    bottom
    {
        type            atmEpsilonWallFunction;
        z0              uniform {{ inflow.z0_eff | default(0.05) }};
        value           uniform {{ "%.6e" | format(epsilon_init) }};
    }
}

