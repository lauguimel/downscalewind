/*
 * fvSolution.j2 — Linear solvers and SIMPLE settings for simpleFoam
 * Incompressible k-epsilon, ABL over complex terrain (Perdigão)
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    // -- Phi (velocity potential solved by potentialFoam for div-free init) --
    Phi
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-7;
        relTol          0.01;
        maxIter         200;
    }

    // -- Pressure --
    //    PCG+DIC: robust for all mesh sizes (no coarsening threshold issues).
    p
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-7;
        relTol          0.01;
        maxIter         200;
    }

    pFinal
    {
        $p;
        relTol          0;
    }

    // -- Modified pressure p_rgh (for buoyantSimpleFoam) --
    p_rgh
    {
        $p;
    }

    p_rghFinal
    {
        $p;
        relTol          0;
    }

    // -- Velocity --
    U
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;
        relTol          0.1;
        maxIter         50;
    }

    UFinal
    {
        $U;
        relTol          0;
    }

    // -- Turbulent kinetic energy --
    k
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;
        relTol          0.1;
        maxIter         50;
    }

    kFinal
    {
        $k;
        relTol          0;
    }

    // -- Turbulent dissipation rate --
    epsilon
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;
        relTol          0.1;
        maxIter         50;
    }

    epsilonFinal
    {
        $epsilon;
        relTol          0;
    }
{% if solver.thermal | default(false) %}

    // -- Temperature --
    T
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;
        relTol          0.1;
        maxIter         50;
    }

    TFinal
    {
        $T;
        relTol          0;
    }
{% if solver.name | default('simpleFoam') == 'buoyantSimpleFoam' %}

    // -- Enthalpy / Internal energy (buoyantSimpleFoam with heRhoThermo) --
    h
    {
        $T;
    }

    hFinal
    {
        $T;
        relTol          0;
    }

    e
    {
        $T;
    }

    eFinal
    {
        $T;
        relTol          0;
    }
{% endif %}
{% endif %}
}

// ---------------------------------------------------------------------------
// potentialFoam settings (used for divergence-free initialisation)
// ---------------------------------------------------------------------------
potentialFlow
{
    nNonOrthogonalCorrectors 10;
    PhiRefCell      0;
    PhiRefValue     0;
}

// ---------------------------------------------------------------------------
// SIMPLE algorithm (steady-state incompressible)
// ---------------------------------------------------------------------------
SIMPLE
{
    // 3 correctors needed for terrain meshes with maxNonOrtho > 70°
    nNonOrthogonalCorrectors 3;

    residualControl
    {
        p               1e-4;
        U               1e-4;
        k               1e-4;
        epsilon         1e-4;
{% if solver.name | default('simpleFoam') == 'buoyantSimpleFoam' %}
        p_rgh           1e-4;
        h               1e-4;
        e               1e-4;
{% endif %}
    }
}

// ---------------------------------------------------------------------------
// Relaxation factors
// ---------------------------------------------------------------------------
relaxationFactors
{
    fields
    {
        p               0.3;
{% if solver.name | default('simpleFoam') == 'buoyantSimpleFoam' %}
        p_rgh           0.3;
{% endif %}
    }

    equations
    {
        U               0.7;
        k               0.5;
        epsilon         0.5;
{% if solver.thermal | default(false) %}
        T               0.7;
{% endif %}
{% if solver.name | default('simpleFoam') == 'buoyantSimpleFoam' %}
        h               0.7;
        e               0.7;
{% endif %}
    }
}

