/*
 * fvSolution.j2 — Linear solvers and SIMPLE settings for simpleFoam
 * Incompressible k-epsilon, ABL over complex terrain (Perdigão)
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    // -- Phi (velocity potential solved by potentialFoam for div-free init) --
    Phi
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-7;
        relTol          0.01;
        maxIter         200;
    }

    // -- Pressure --
    //    PCG+DIC: robust for all mesh sizes (no coarsening threshold issues).
    p
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-7;
        relTol          0.01;
        maxIter         200;
    }

    pFinal
    {
        $p;
        relTol          0;
    }

    // -- Modified pressure p_rgh (for buoyantSimpleFoam) --
    //    GAMG: algebraic multigrid — 3-5 V-cycles vs O(N) PCG iterations.
    //    Typically 3-5× faster than PCG+DIC on meshes > 500k cells.
    p_rgh
    {
        solver              GAMG;
        smoother            GaussSeidel;
        tolerance           1e-7;
        relTol              0.01;
        nPreSweeps          0;
        nPostSweeps         2;
        cacheAgglomeration  on;
        agglomerator        faceAreaPair;
        nCellsInCoarsestLevel 20;
        mergeLevels         1;
    }

    p_rghFinal
    {
        $p_rgh;
        relTol          0;
    }

    // -- Velocity --
    U
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;
        relTol          0.1;
        maxIter         50;
    }

    UFinal
    {
        $U;
        relTol          0;
    }

    // -- Turbulent kinetic energy --
    k
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;
        relTol          0.1;
        maxIter         50;
    }

    kFinal
    {
        $k;
        relTol          0;
    }

    // -- Turbulent dissipation rate --
    epsilon
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;
        relTol          0.1;
        maxIter         50;
    }

    epsilonFinal
    {
        $epsilon;
        relTol          0;
    }
{% if solver.thermal | default(false) or solver.transport_T | default(false) %}

    // -- Temperature --
    T
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;
        relTol          0.1;
        maxIter         50;
    }

    TFinal
    {
        $T;
        relTol          0;
    }
{% if solver.name | default('simpleFoam') == 'buoyantSimpleFoam' %}

    // -- Enthalpy / Internal energy (buoyantSimpleFoam with heRhoThermo) --
    h
    {
        $T;
    }

    hFinal
    {
        $T;
        relTol          0;
    }

    e
    {
        $T;
    }

    eFinal
    {
        $T;
        relTol          0;
    }
{% endif %}
{% endif %}
}

// ---------------------------------------------------------------------------
// potentialFoam settings (used for divergence-free initialisation)
// ---------------------------------------------------------------------------
potentialFlow
{
    nNonOrthogonalCorrectors 10;
    PhiRefCell      0;
    PhiRefValue     0;
}

// ---------------------------------------------------------------------------
// SIMPLE algorithm (steady-state incompressible)
// ---------------------------------------------------------------------------
SIMPLE
{
    consistent      yes;        // SIMPLEC: pressure-corrected URF, allows U~0.7 vs 0.3
    nNonOrthogonalCorrectors {{ solver.n_non_ortho_correctors | default(0) }};

    // Bounds to prevent k/epsilon from going to zero or negative on complex terrain.
    // epsilonMin=1e-8 is critical: if epsilon→0, nut=Cmu*k²/epsilon→∞, G→∞,
    // k→∞, and the next PBiCGStab sumProd() gets NaN → SIGFPE in kEpsilon::correct.
    // kMin=1e-10 matches the observed natural minimum on corner cells.
    kMin        1e-10;
    epsilonMin  1e-8;

    // No pRefCell: pressure anchored by fixedValue p_rgh(ERA5) at top.

    residualControl
    {
{% if solver.name | default('simpleFoam') == 'buoyantBoussinesqSimpleFoam' %}
        p_rgh           5e-4;   // relaxed: p_rgh oscillates in terrain cases
{% else %}
        p               1e-4;
{% endif %}
        U               1e-4;
        k               1e-4;
        epsilon         1e-4;
{% if solver.thermal | default(false) or solver.transport_T | default(false) %}
        T               1e-4;
{% endif %}
{% if solver.name | default('simpleFoam') == 'buoyantSimpleFoam' %}
        p_rgh           1e-4;
        h               1e-4;
{% endif %}
    }
}

// ---------------------------------------------------------------------------
// Relaxation factors (following OF2412 hotRoom tutorial pattern)
//   p_rgh: 0.7 (field), U: 0.3 (equation) — standard for buoyant SIMPLE
// ---------------------------------------------------------------------------
relaxationFactors
{
    fields
    {
{% if solver.name | default('simpleFoam') == 'buoyantBoussinesqSimpleFoam' %}
        p_rgh           0.4;
{% else %}
        p               0.3;
{% endif %}
    }

    equations
    {
{% if solver.name | default('simpleFoam') == 'buoyantBoussinesqSimpleFoam' %}
        U               0.3;
        T               0.3;
        "(k|epsilon)"   0.05;   // very conservative — prevent eps wall function shock
{% else %}
        U               0.7;
        k               0.7;
        epsilon         0.7;
{% if solver.thermal | default(false) or solver.transport_T | default(false) %}
        T               0.5;
{% endif %}
{% endif %}
{% if solver.name | default('simpleFoam') == 'buoyantSimpleFoam' %}
        h               0.1;
        e               0.1;
{% endif %}
    }
}

// ************************************************************************* //
