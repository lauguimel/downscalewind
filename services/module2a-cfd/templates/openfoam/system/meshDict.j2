/*
 * meshDict.j2 — Jinja2 template for cfMesh cartesianMesh
 * ABL simulation on complex terrain (SRTM STL)
 *
 * Variables (from generate_mesh.py):
 *   mesh.max_cell_size          — outer zone cell size [m]
 *   mesh.target_cell_size       — central zone cell size [m] (= resolution_m)
 *   mesh.terrain_refine_levels  — additional refinement levels on terrain surface
 *   mesh.terrain_refine_thickness — thickness of terrain refinement zone [m]
 *   mesh.n_boundary_layers      — number of prism layers on terrain
 *   mesh.bl_expansion           — boundary layer expansion ratio
 *   mesh.bl_first_layer         — max first layer thickness [m]
 *   domain.*                    — bounding box coordinates or octagonal domain info
 *   cfmesh_refinements          — list of objectRefinement dicts (box mode only)
 *   domain.octagonal            — True for cylindrical/octagonal domain, False for box
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      meshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

{% if domain.octagonal %}
// ---------------------------------------------------------------------------
// Octagonal (cylindrical) domain
// Closed surface: terrain (bottom) + octagon prism (lateral + top)
// ---------------------------------------------------------------------------
surfaceFile "constant/triSurface/domain_octagon.stl";

// ---------------------------------------------------------------------------
// Global cell size — controls the coarsest cells in the outer zone
// ---------------------------------------------------------------------------
maxCellSize {{ mesh.max_cell_size }};

// ---------------------------------------------------------------------------
// Surface refinement on terrain
// ---------------------------------------------------------------------------
surfaceMeshRefinement
{
    terrain
    {
        surfaceFile "constant/triSurface/terrain.stl";
        additionalRefinementLevels {{ mesh.terrain_refine_levels }};
        refinementThickness {{ mesh.terrain_refine_thickness }};
    }
}

// ---------------------------------------------------------------------------
// Object-based refinement zones — 3-ring structure
//   Sizes computed by generate_mesh.py based on domain radius
// ---------------------------------------------------------------------------
objectRefinements
{
{%- for ref in cfmesh_refinements %}
    {{ ref.name }}
    {
        type        box;
        cellSize    {{ ref.cell_size }};
        centre      ( {{ ref.cx }} {{ ref.cy }} {{ ref.cz }} );
        lengthX     {{ ref.lx }};
        lengthY     {{ ref.ly }};
        lengthZ     {{ ref.lz }};
    }
{%- endfor %}
}

// ---------------------------------------------------------------------------
// Boundary layers on terrain surface
// ---------------------------------------------------------------------------
boundaryLayers
{
    nLayers {{ mesh.n_boundary_layers }};
    thicknessRatio {{ mesh.bl_expansion }};
    maxFirstLayerThickness {{ mesh.bl_first_layer }};

    patchBoundaryLayers
    {
        "terrain.*"
        {
            nLayers {{ mesh.n_boundary_layers }};
            thicknessRatio {{ mesh.bl_expansion }};
            maxFirstLayerThickness {{ mesh.bl_first_layer }};
        }
    }
}

// ---------------------------------------------------------------------------
// Rename patches — octagonal domain
//   lateral: all 8 vertical faces of the octagon STL solid "lateral"
//   top:     the top cap of the octagon STL solid "top"
//   terrain: terrain surface
// ---------------------------------------------------------------------------
renameBoundary
{
    defaultName     fixedWalls;
    defaultType     wall;

    newPatchNames
    {
        "lateral"
        {
            newName     lateral;
            type        patch;
        }
        "top"
        {
            newName     top;
            type        patch;
        }
        "terrain.*"
        {
            newName     terrain;
            type        wall;
        }
    }
}

// ---------------------------------------------------------------------------
// Mesh quality controls
// ---------------------------------------------------------------------------
meshQualitySettings
{
    maxNonOrthogonality     50;
}

{% else %}
// ---------------------------------------------------------------------------
// Box domain (default)
// ---------------------------------------------------------------------------
// Domain surface (FMS format, generated by surfaceGenerateBoundingBox)
// Contains terrain STL + 5 bounding box faces (xMin, xMax, yMin, yMax, zMax)
// ---------------------------------------------------------------------------
surfaceFile "constant/triSurface/domain.stl";

// ---------------------------------------------------------------------------
// Global cell size — controls the coarsest cells in the outer zone
// ---------------------------------------------------------------------------
maxCellSize {{ mesh.max_cell_size }};

// ---------------------------------------------------------------------------
// Surface refinement on terrain
//   additionalRefinementLevels: each level halves the cell size (octree)
//   refinementThickness: distance from surface to refine [m]
// ---------------------------------------------------------------------------
surfaceMeshRefinement
{
    terrain
    {
        surfaceFile "constant/triSurface/terrain.stl";
        additionalRefinementLevels {{ mesh.terrain_refine_levels }};
        refinementThickness {{ mesh.terrain_refine_thickness }};
    }
}

// ---------------------------------------------------------------------------
// Object-based refinement zones
//   Boxes define regions where cell size is explicitly controlled.
//   cfMesh ensures smooth 2:1 transitions between zones automatically.
// ---------------------------------------------------------------------------
objectRefinements
{
{%- for ref in cfmesh_refinements %}
    {{ ref.name }}
    {
        type        box;
        cellSize    {{ ref.cell_size }};
        centre      ( {{ ref.cx }} {{ ref.cy }} {{ ref.cz }} );
        lengthX     {{ ref.lx }};
        lengthY     {{ ref.ly }};
        lengthZ     {{ ref.lz }};
    }
{%- endfor %}
}

// ---------------------------------------------------------------------------
// Boundary layers on terrain surface
//   Prism layers for wall-resolved k-epsilon turbulence closure
// ---------------------------------------------------------------------------
boundaryLayers
{
    nLayers {{ mesh.n_boundary_layers }};
    thicknessRatio {{ mesh.bl_expansion }};
    maxFirstLayerThickness {{ mesh.bl_first_layer }};

    patchBoundaryLayers
    {
        "terrain.*"
        {
            nLayers {{ mesh.n_boundary_layers }};
            thicknessRatio {{ mesh.bl_expansion }};
            maxFirstLayerThickness {{ mesh.bl_first_layer }};
        }
    }
}

// ---------------------------------------------------------------------------
// Rename patches created by surfaceGenerateBoundingBox
//   Maps cfMesh default names to the BC patch names used in 0/ templates
// ---------------------------------------------------------------------------
renameBoundary
{
    defaultName     fixedWalls;
    defaultType     wall;

    newPatchNames
    {
        "xMin"
        {
            newName     west;
            type        patch;
        }
        "xMax"
        {
            newName     east;
            type        patch;
        }
        "yMin"
        {
            newName     south;
            type        patch;
        }
        "yMax"
        {
            newName     north;
            type        patch;
        }
        "zMax"
        {
            newName     top;
            type        patch;
        }
        "terrain.*"
        {
            newName     terrain;
            type        wall;
        }
    }
}

// ---------------------------------------------------------------------------
// Mesh quality controls
// ---------------------------------------------------------------------------
meshQualitySettings
{
    maxNonOrthogonality     50;
}

{% endif %}
// ************************************************************************* //
