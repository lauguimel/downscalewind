FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      surfaceFeaturesDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Extract feature edges from terrain STL for snappyHexMesh.
// OF v10: uses surfaceFeatures utility (replaces surfaceFeatureExtract).
// Output: constant/triSurface/terrain.eMesh

surfaces
(
    "{{ terrain.stl_file }}"
);

includedAngle   150;    // Feature edge threshold: normals differ > (180-150)=30°

writeObj        yes;    // Write terrain.obj for visualisation

