FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      surfaceFeatureExtractDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Extract feature edges from the terrain STL for snappyHexMesh.
// Output: constant/triSurface/terrain.eMesh

{{ terrain.stl_file }}
{
    extractionMethod    extractFromSurface;

    extractFromSurfaceCoeffs
    {
        // Feature angle threshold [degrees].
        // Edges where the surface normal changes by more than this angle
        // are treated as feature edges (ridge lines, valleys).
        includedAngle   150;
    }

    writeObj            yes;    // Also write terrain.obj for visualisation
}

