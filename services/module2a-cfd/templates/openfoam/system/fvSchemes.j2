/*
 * fvSchemes.j2 — Jinja2 template
 * Discretisation schemes for simpleFoam with k-epsilon
 * ABL flow over complex terrain (Perdigão)
 *
 * No Jinja2 variables required in this file — schemes are fixed for the
 * physics configuration. Include this template directly or extend as needed.
 */
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// ---------------------------------------------------------------------------
// Time derivative schemes
//   steadyState — correct for SIMPLE steady-state solvers.
// ---------------------------------------------------------------------------
ddtSchemes
{
    default         steadyState;
}

// ---------------------------------------------------------------------------
// Gradient schemes
//   Gauss linear: second-order central-difference on all fields.
//   cellLimited: bounds gradient to prevent overshoots on skewed cells.
// ---------------------------------------------------------------------------
gradSchemes
{
{%- if solver.use_limited_grad | default(false) %}
    // Tighter gradient limiting (0.5) — reduces velocity spikes at mesh transitions
    default         cellLimited Gauss linear 0.5;
    grad(U)         cellLimited Gauss linear 0.5;
    grad(k)         cellLimited Gauss linear 0.5;
    grad(epsilon)   cellLimited Gauss linear 0.5;
    grad(T)         cellLimited Gauss linear 0.5;
{%- else %}
    default         Gauss linear;
    grad(U)         cellLimited Gauss linear 1;
    grad(k)         cellLimited Gauss linear 1;
    grad(epsilon)   cellLimited Gauss linear 1;
    grad(T)         cellLimited Gauss linear 1;
{%- endif %}
}

// ---------------------------------------------------------------------------
// Divergence (convection) schemes
//   U:     linearUpwind — bounded second-order, uses grad(U) limiter.
//          Stable on complex terrain meshes while preserving accuracy.
//   k,ε,T: limitedLinear 1 — TVD-limited linear; ensures boundedness of
//          positive-definite scalars (k ≥ 0, ε > 0, T > 0).
//   phi:   linear for face interpolation of flux.
// ---------------------------------------------------------------------------
divSchemes
{
    default                         none;

    // Momentum — linearUpwind with gradient limiter (bounded for robustness)
    div(phi,U)                      bounded Gauss linearUpwind grad(U);

    // Turbulence scalars — bounded upwind (robust for complex terrain)
    div(phi,k)                      bounded Gauss upwind;
    div(phi,epsilon)                bounded Gauss upwind;

    // Turbulent diffusion (dev2 operator)
    // simpleFoam: div((nuEff*dev2(T(grad(U)))))
    // buoyantSimpleFoam: div(((rho*nuEff)*dev2(T(grad(U)))))
    div((nuEff*dev2(T(grad(U)))))           Gauss linear;
    div(((rho*nuEff)*dev2(T(grad(U)))))     Gauss linear;
{% if solver.thermal | default(false) or solver.transport_T | default(false) %}

    // Temperature — bounded linearUpwind
    div(phi,T)                          bounded Gauss linearUpwind grad(T);
{% if solver.name | default('simpleFoam') == 'buoyantSimpleFoam' %}

    // Energy transport — buoyantSimpleFoam (heRhoThermo)
    // sensibleEnthalpy → h; sensibleInternalEnergy → e
    // First-order upwind: unconditionally stable for rhoConst (energy is
    // passive/decoupled); linearUpwind caused T divergence on first iterations.
    div(phi,h)                          bounded Gauss upwind;
    div(phi,e)                          bounded Gauss upwind;
    div(phi,K)                          bounded Gauss upwind;
    div(phi,Ekp)                        bounded Gauss upwind;
{% endif %}
{% endif %}
}

// ---------------------------------------------------------------------------
// Laplacian schemes
//   Gauss linear limited corrected 0.5
//   'limited corrected' bounds the non-orthogonal correction to avoid
//   divergence on highly non-orthogonal terrain cells.  The coefficient
//   0.5 is a good compromise for typical snappy meshes with non-ortho < 70°.
// ---------------------------------------------------------------------------
laplacianSchemes
{
    default         Gauss linear limited corrected 0.5;
}

// ---------------------------------------------------------------------------
// Interpolation schemes
//   linear: second-order face interpolation (default).
// ---------------------------------------------------------------------------
interpolationSchemes
{
    default         linear;
}

// ---------------------------------------------------------------------------
// Surface-normal gradient schemes
//   limited corrected 0.5: same non-orthogonal correction as laplacian.
// ---------------------------------------------------------------------------
snGradSchemes
{
    default         limited corrected 0.5;
}

// ---------------------------------------------------------------------------
// Wall distance method (used by wall functions)
// ---------------------------------------------------------------------------
wallDist
{
    method          meshWave;
}

// ************************************************************************* //
